<!-- HERO -->
<section class="hero">
  <div class="hero-overlay"></div>
  <div class="hero-inner">
    <div class="hero-text fade-in">
      <div class="hero-eyebrow">Phoenix, AZ &nbsp;&middot;&nbsp; Hereford, TX Roots</div>
