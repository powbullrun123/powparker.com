<style>
  :root {
    --gold: #C9A84C;
    --gold-light: #E8D5A3;
    --gold-dim: #8a6f2e;
    --dark: #1a2e42;
    --navy: #1B2A40;
    --deep: #071018;
    --light: #F5F0E8;
    --cream: #FAF7F2;
    --text: #2a2a2a;
    --muted: #666;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { font-family: 'Lato', sans-serif; background: var(--cream); color: var(--text); overflow-x: hidden; }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 200;
    display: flex; justify-content: space-between; align-items: center;
    padding: 20px 48px;
    background: rgba(7,16,24,0.94);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(201,168,76,0.15);
    transition: padding 0.3s;
  }
  nav.scrolled { padding: 13px 48px; }
  .nav-logo {
    font-family: 'Playfair Display', serif; font-size: 1.05rem; font-weight: 700;
    color: var(--gold); letter-spacing: 0.04em; text-decoration: none;
  }
  .nav-links { display: flex; gap: 34px; list-style: none; }
  .nav-links a {
    font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em;
    text-transform: uppercase; color: rgba(245,240,232,0.65); text-decoration: none;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--gold); }

  /* Mobile nav */
  #menuBtn {
    display: none; background: none; border: none; cursor: pointer;
    flex-direction: column; gap: 5px; padding: 4px;
  }
  #menuBtn span { display: block; width: 24px; height: 2px; background: var(--gold); }
  #navMenu {
    display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0;
    background: var(--deep); z-index: 300; flex-direction: column;
    align-items: center; justify-content: center; gap: 36px;
  }
  #navMenu.open { display: flex; }
  #navMenu a {
    font-family: 'Playfair Display', serif; font-size: 1.8rem; font-weight: 700;
    color: var(--light); text-decoration: none; transition: color 0.2s;
  }
  #navMenu a:hover { color: var(--gold); }
  #navClose {
    position: absolute; top: 24px; right: 32px;
    background: none; border: none; color: var(--gold); font-size: 2rem; cursor: pointer;
  }

  /* HERO */
  .hero {
    position: relative; min-height: 100vh; display: flex; align-items: center;
    background: var(--deep); overflow: hidden;
  }
  .hero-overlay {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 70% 65% at 68% 50%, rgba(201,168,76,0.06) 0%, transparent 65%);
    pointer-events: none;
  }
  .hero-inner {
    position: relative; z-index: 2;
    max-width: 1180px; margin: 0 auto; padding: 130px 60px 90px;
    display: grid; grid-template-columns: 1fr 380px; gap: 80px; align-items: center;
    width: 100%;
  }
  .hero-eyebrow {
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.22em;
    text-transform: uppercase; color: var(--gold);
    display: flex; align-items: center; gap: 14px; margin-bottom: 22px;
  }
  .hero-eyebrow::before { content: ''; width: 36px; height: 1px; background: var(--gold); }
  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.8rem, 5.5vw, 5rem);
    font-weight: 900; line-height: 1.04; color: #fff; margin-bottom: 26px;
  }
  .hero h1 em { font-style: italic; color: var(--gold); }
  .hero-sub {
    font-family: 'Cormorant Garamond', serif; font-size: 1.25rem; font-style: italic;
    color: var(--gold-light); opacity: 0.88; line-height: 1.65;
    margin-bottom: 42px; max-width: 460px;
  }
  .btn-gold {
    display: inline-block; background: var(--gold); color: var(--deep);
    font-size: 0.78rem; font-weight: 700; letter-spacing: 0.15em;
    text-transform: uppercase; padding: 16px 34px; text-decoration: none;
    transition: background 0.2s, transform 0.15s;
  }
  .btn-gold:hover { background: var(--gold-light); transform: translateY(-2px); }
  .btn-ghost {
    display: inline-block; border: 1px solid rgba(201,168,76,0.38);
    color: var(--gold-light); font-size: 0.78rem; font-weight: 700;
    letter-spacing: 0.15em; text-transform: uppercase; padding: 15px 34px;
    text-decoration: none; margin-left: 16px; transition: border-color 0.2s, color 0.2s;
  }
  .btn-ghost:hover { border-color: var(--gold); color: var(--gold); }

  .hero-photo-wrap { position: relative; }
  .hero-photo-frame {
    position: relative; width: 100%; aspect-ratio: 3/4; overflow: hidden; background: var(--navy);
  }
  .hero-photo-frame::after {
    content: ''; position: absolute; inset: 0;
    border: 1px solid rgba(201,168,76,0.22); z-index: 2; pointer-events: none;
  }
  .hero-photo-frame img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .photo-placeholder {
    width: 100%; height: 100%; min-height: 420px;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    background: linear-gradient(160deg, #1B2A40 0%, #071018 100%);
    color: rgba(201,168,76,0.3); font-family: 'Cormorant Garamond', serif;
    font-style: italic; font-size: 0.9rem; letter-spacing: 0.06em; gap: 14px; text-align: center;
  }
  .photo-placeholder svg { width: 46px; height: 46px; opacity: 0.25; }
  .hero-accent {
    position: absolute; bottom: -18px; right: -18px;
    width: 55%; height: 55%; border: 1px solid rgba(201,168,76,0.12); pointer-events: none;
  }
  .hero-badge {
    position: absolute; bottom: 22px; left: -18px; background: var(--gold); color: var(--deep);
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 10px 18px; z-index: 3; box-shadow: 0 6px 22px rgba(0,0,0,0.45);
  }

  /* STAT BAR */
  .stat-bar {
    background: var(--navy); padding: 30px 40px; display: flex; justify-content: center;
    border-top: 1px solid rgba(201,168,76,0.18); border-bottom: 1px solid rgba(201,168,76,0.18);
  }
  .stat-item {
    text-align: center; padding: 0 52px;
    border-right: 1px solid rgba(201,168,76,0.13); flex: 1; max-width: 220px;
  }
  .stat-item:last-child { border-right: none; }
  .stat-num {
    font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 700;
    color: var(--gold); line-height: 1; display: block; margin-bottom: 6px;
  }
  .stat-label {
    font-size: 0.68rem; font-weight: 700; letter-spacing: 0.13em;
    text-transform: uppercase; color: rgba(245,240,232,0.5);
  }

  /* SECTIONS */
  section { padding: 96px 40px; }
  .container { max-width: 1100px; margin: 0 auto; }
  .section-eyebrow {
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.22em;
    text-transform: uppercase; color: var(--gold-dim);
    margin-bottom: 14px; display: flex; align-items: center; gap: 12px;
  }
  .section-eyebrow::before { content: ''; width: 28px; height: 1px; background: var(--gold-dim); }
  .section-title {
    font-family: 'Playfair Display', serif; font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 700; line-height: 1.15; color: var(--dark); margin-bottom: 20px;
  }
  .section-lead {
    font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; font-style: italic;
    color: var(--muted); line-height: 1.7; max-width: 620px;
  }
  .section-divider { width: 60px; height: 2px; background: var(--gold); margin: 28px 0; }

  /* WHAT DRIVES ME */
  .drives-section { background: #fff; }
  .drives-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 0;
    margin-top: 64px; border: 1px solid rgba(27,42,64,0.1);
  }
  .drives-photo { position: relative; aspect-ratio: 4/5; background: var(--navy); overflow: hidden; }
  .drives-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .drives-content {
    padding: 64px 52px; display: flex; flex-direction: column; justify-content: center;
    background: var(--deep); color: var(--light);
  }
  .drives-content .section-title { color: var(--light); font-size: clamp(1.6rem, 2.6vw, 2.3rem); }
  .drives-content p { font-size: 0.96rem; line-height: 1.8; color: rgba(245,240,232,0.75); margin-top: 16px; }
  .drives-content p + p { margin-top: 12px; }

  .pillars { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; margin-top: 1px; }
  .pillar {
    background: rgba(255,255,255,0.03); padding: 32px 26px;
    border-top: 2px solid transparent; transition: border-color 0.3s;
  }
  .pillar:hover { border-color: var(--gold); }
  .pillar-icon { font-size: 1.3rem; margin-bottom: 12px; }
  .pillar-title {
    font-family: 'Playfair Display', serif; font-size: 0.95rem; font-style: italic;
    color: var(--gold-light); margin-bottom: 9px;
  }
  .pillar p { font-size: 0.85rem; line-height: 1.75; color: rgba(245,240,232,0.55); }

  /* RRR */
  .rrr-section { background: var(--cream); }
  .rrr-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; margin-top: 60px; }
  .rrr-photo { position: relative; overflow: hidden; background: var(--navy); }
  .rrr-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .rrr-accent { position: absolute; top: -14px; left: -14px; right: 14px; bottom: 14px; border: 1px solid rgba(201,168,76,0.2); z-index: 0; pointer-events: none; }
  .rrr-photo .photo-placeholder { position: relative; z-index: 1; aspect-ratio: 16/10; }
  .rrr-text p { font-size: 0.97rem; line-height: 1.8; color: var(--muted); margin-bottom: 16px; }
  .rrr-link {
    display: inline-flex; align-items: center; gap: 8px;
    color: var(--gold); font-size: 0.78rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none;
    border-bottom: 1px solid transparent; transition: border-color 0.2s; margin-top: 8px;
  }
  .rrr-link:hover { border-color: var(--gold); }
  .rrr-link svg { transition: transform 0.2s; }
  .rrr-link:hover svg { transform: translateX(4px); }

  /* LIFE OUTSIDE */
  .life-section { background: var(--deep); }
  .life-section .section-eyebrow { color: rgba(201,168,76,0.6); }
  .life-section .section-eyebrow::before { background: rgba(201,168,76,0.4); }
  .life-section .section-title { color: var(--light); }
  .life-section .section-divider { background: var(--gold); opacity: 0.5; }
  .life-section .section-lead { color: rgba(245,240,232,0.6); }
  .photo-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 56px; }
  .photo-cell { position: relative; overflow: hidden; background: var(--navy); }
  .photo-cell:first-child { grid-column: span 2; }
  .photo-cell img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.5s; }
  .photo-cell:hover img { transform: scale(1.04); }
  .photo-caption {
    position: absolute; bottom: 0; left: 0; right: 0; padding: 28px 20px 14px;
    background: linear-gradient(transparent, rgba(7,16,24,0.75));
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em;
    text-transform: uppercase; color: rgba(245,240,232,0.7);
  }
  .photo-cell .photo-placeholder { min-height: 280px; }
  .photo-cell:first-child .photo-placeholder { min-height: 300px; aspect-ratio: 16/9; }

  /* GIVING */
  .giving-section { background: #fff; }
  .giving-intro { font-size: 0.97rem; line-height: 1.8; color: var(--muted); max-width: 640px; margin-top: 16px; }
  .charity-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; margin-top: 56px; }
  .charity-card {
    padding: 40px 32px; border: 1px solid rgba(27,42,64,0.1); text-align: center;
    transition: border-color 0.3s, box-shadow 0.3s;
  }
  .charity-card:hover { border-color: var(--gold); box-shadow: 0 8px 32px rgba(201,168,76,0.08); }
  .charity-icon { font-size: 2.2rem; margin-bottom: 18px; }
  .charity-name {
    font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700;
    color: var(--dark); margin-bottom: 10px;
  }
  .charity-desc { font-size: 0.88rem; line-height: 1.7; color: var(--muted); }

  /* CONTACT */
  .contact-section { background: var(--navy); }
  .contact-section .section-eyebrow { color: rgba(201,168,76,0.65); }
  .contact-section .section-eyebrow::before { background: rgba(201,168,76,0.45); }
  .contact-section .section-title { color: var(--light); }
  .contact-section .section-lead { color: rgba(245,240,232,0.6); max-width: 560px; margin-top: 12px; }
  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; margin-top: 60px; }
  .contact-method { display: flex; align-items: flex-start; gap: 18px; margin-bottom: 28px; }
  .contact-method-icon {
    width: 44px; height: 44px; background: rgba(201,168,76,0.1);
    display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 1.1rem;
  }
  .contact-method-label {
    font-size: 0.68rem; font-weight: 700; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--gold); margin-bottom: 4px;
  }
  .contact-method-value { font-size: 1rem; color: var(--light); text-decoration: none; transition: color 0.2s; }
  a.contact-method-value:hover { color: var(--gold); }
  .contact-note { font-size: 0.84rem; color: rgba(245,240,232,0.45); margin-top: 4px; }
  .contact-rrr {
    background: rgba(201,168,76,0.07); padding: 36px 32px;
    border: 1px solid rgba(201,168,76,0.18); display: flex; flex-direction: column; justify-content: center;
  }
  .contact-rrr-title {
    font-family: 'Playfair Display', serif; font-size: 1.1rem; font-style: italic;
    color: var(--gold-light); margin-bottom: 12px;
  }
  .contact-rrr p { font-size: 0.9rem; line-height: 1.75; color: rgba(245,240,232,0.6); margin-bottom: 24px; }

  /* FOOTER */
  footer {
    background: var(--deep); border-top: 1px solid rgba(201,168,76,0.12);
    padding: 32px 60px; display: flex; justify-content: space-between; align-items: center;
  }
  .footer-name {
    font-family: 'Playfair Display', serif; font-size: 0.95rem; color: var(--gold); font-weight: 700;
  }
  .footer-copy { font-size: 0.75rem; color: rgba(245,240,232,0.35); letter-spacing: 0.04em; }
  .footer-copy a { color: inherit; text-decoration: none; }

  /* FADE-IN */
  .fade-in { opacity: 0; transform: translateY(28px); transition: opacity 0.65s ease, transform 0.65s ease; }
  .fade-in.visible { opacity: 1; transform: none; }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    nav { padding: 18px 24px; }
    .nav-links { display: none; }
    #menuBtn { display: flex; }
    .hero-inner { grid-template-columns: 1fr; padding: 110px 28px 64px; gap: 44px; }
    .hero-photo-wrap { order: -1; max-width: 300px; margin: 0 auto; }
    .hero h1 { font-size: 2.6rem; }
    .stat-bar { flex-wrap: wrap; gap: 28px; padding: 28px 24px; }
    .stat-item { border-right: none; padding: 0 20px; max-width: 50%; }
    section { padding: 64px 24px; }
    .drives-grid { grid-template-columns: 1fr; }
    .drives-photo { aspect-ratio: 16/9; }
    .drives-content { padding: 40px 28px; }
    .pillars { grid-template-columns: 1fr; }
    .rrr-grid { grid-template-columns: 1fr; gap: 40px; }
    .photo-row { grid-template-columns: 1fr 1fr; }
    .photo-cell:first-child { grid-column: span 2; }
    .charity-grid { grid-template-columns: 1fr; max-width: 420px; }
    .contact-grid { grid-template-columns: 1fr; gap: 40px; }
    footer { flex-direction: column; gap: 10px; text-align: center; padding: 28px 24px; }
  }
  @media (max-width: 540px) {
    .btn-ghost { margin-left: 0; margin-top: 14px; display: block; width: fit-content; }
    .photo-row { grid-template-columns: 1fr; }
    .photo-cell:first-child { grid-column: span 1; }
  }
</style>
</head>
